# ============================================================
# TONHO SUPLEMENTOS — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# ============================================================

# SUPABASE (obrigatório)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Site URL (para redirects de auth)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin: e-mails separados por vírgula (alternativa à tabela admin_users)
ADMIN_EMAILS=seu@email.com

# Instagram OAuth (opcional — deixe em branco para usar stub)
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
